[sub_resource type="GDScript" id="GDScript_mrjyg"]
resource_name = "yea"
script/source = "extends CustomWindow

@onready var butt = $Control/Panel/Button

var score = 0

func _ready() -> void:
	score = Config.get_value(\"extra\", \"clicker_score\")
	%ScoreLabel.text = str(score)

func _process(_delta: float) -> void:
	butt.scale.x = lerpf(butt.scale.x, 1, 0.08)
	butt.scale.y = lerpf(butt.scale.y, 1, 0.08)
	butt.rotation_degrees = lerpf(butt.rotation_degrees, 0, 0.08)

var drag_offset = Vector2.ZERO
var is_dragging = false
func _input(event):
	if event is InputEventKey and event.pressed:
		if Input.is_key_pressed(KEY_CTRL) and Input.is_key_pressed(KEY_SHIFT) and Input.is_key_pressed(KEY_ALT) and event.keycode == KEY_R:
			score = 0
			%ScoreLabel.text = str(score)
			Config.set_value(\"extra\", \"clicker_score\", score)
	if is_dragging:
		var current_mouse_pos: Vector2 = DisplayServer.mouse_get_position()
		var window_pos: Vector2 = current_mouse_pos - drag_offset
		self.position =  window_pos

func _on_drag_button_button_down() -> void:
	is_dragging = true
	drag_offset = get_viewport().get_mouse_position()

func _on_drag_button_button_up() -> void:
	is_dragging = false
	drag_offset = Vector2.ZERO

func _on_close_button_pressed() -> void:
	close()
	pass # Replace with function body.

func _on_button_pressed() -> void:
	score = score + 1
	butt.scale.x = 1.8
	butt.scale.y = 0.6
	butt.rotation_degrees = butt.rotation_degrees + randf_range(-10, 10)
	$Control/Panel/Button/Click.play()
	%ScoreLabel.text = str(score)
	Config.set_value(\"extra\", \"clicker_score\", score)
	pass # Replace with function body.
"

